<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Book Consultation — Adv. Devesh Chandra Gupta</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --navy: #0f2044; --gold: #c9a84c; --gold-light: #e8c97a;
      --white: #ffffff; --off-white: #f6f7fa;
      --green: #16a34a; --wa: #25D366;
    }
    body { font-family: 'DM Sans', sans-serif; background: var(--off-white); min-height: 100vh; }

    /* TOP BAR */
    .topbar { background: var(--navy); padding: 14px 20px; text-align: center; border-bottom: 3px solid var(--gold); }
    .topbar-name { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: white; font-weight: 700; }
    .topbar-name span { color: var(--gold); }
    .topbar-sub { font-size: 0.72rem; color: rgba(255,255,255,0.45); margin-top: 3px; letter-spacing: 0.08em; text-transform: uppercase; }

    .page { display: none; }
    .page.active { display: block; }

    .wrap { max-width: 460px; margin: 0 auto; padding: 28px 20px 60px; }

    /* STEP BAR */
    .step-bar { display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 24px; }
    .step { display: flex; align-items: center; gap: 6px; font-size: 0.75rem; font-weight: 600; color: rgba(0,0,0,0.28); letter-spacing: 0.06em; text-transform: uppercase; }
    .step.active { color: var(--navy); }
    .step.done { color: var(--green); }
    .step-num { width: 24px; height: 24px; border-radius: 50%; background: rgba(0,0,0,0.08); display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 700; }
    .step.active .step-num { background: var(--navy); color: white; }
    .step.done .step-num { background: var(--green); color: white; }
    .step-line { flex: 1; height: 1px; background: rgba(0,0,0,0.1); max-width: 36px; }

    /* CARD */
    .card { background: white; border-radius: 20px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.08); }

    /* PAYMENT HEADER */
    .pay-head { background: linear-gradient(135deg, #0a1628 0%, #1a3260 100%); padding: 28px 28px 22px; text-align: center; position: relative; }
    .pay-head::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, transparent, var(--gold), transparent); }
    .pill { display: inline-block; background: rgba(201,168,76,0.15); border: 1px solid rgba(201,168,76,0.35); color: var(--gold-light); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; padding: 6px 16px; border-radius: 100px; margin-bottom: 12px; }
    .pay-head h2 { font-family: 'Playfair Display', serif; font-size: 1.35rem; color: white; margin-bottom: 4px; }
    .pay-head p { font-size: 0.8rem; color: rgba(255,255,255,0.5); }
    .fee-pill { display: inline-flex; align-items: baseline; gap: 2px; background: var(--gold); color: var(--navy); padding: 9px 22px; border-radius: 100px; margin-top: 14px; }
    .fee-pill .cur { font-size: 1rem; font-weight: 700; }
    .fee-pill .amt { font-family: 'Playfair Display', serif; font-size: 1.75rem; font-weight: 900; line-height: 1; }
    .fee-pill .lbl { font-size: 0.75rem; font-weight: 600; margin-left: 4px; opacity: 0.7; }

    /* PAYMENT BODY */
    .pay-body { padding: 24px; }

    .qr-section { text-align: center; margin-bottom: 20px; }
    .qr-lbl { font-size: 0.75rem; font-weight: 600; color: rgba(0,0,0,0.38); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 14px; }
    .qr-frame { background: white; border: 2px solid rgba(15,32,68,0.1); border-radius: 16px; padding: 16px; display: inline-block; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
    .qr-frame img { width: 190px; height: 190px; display: block; object-fit: contain; border-radius: 6px; }
    .qr-apps { font-size: 0.75rem; color: rgba(0,0,0,0.38); margin-top: 12px; }

    .or-divider { display: flex; align-items: center; gap: 10px; margin: 16px 0; color: rgba(0,0,0,0.28); font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; }
    .or-divider::before, .or-divider::after { content: ''; flex: 1; height: 1px; background: rgba(0,0,0,0.08); }

    .upi-row { background: var(--off-white); border: 1.5px solid rgba(15,32,68,0.08); border-radius: 12px; padding: 14px 18px; display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 20px; }
    .upi-lbl { font-size: 0.68rem; color: rgba(0,0,0,0.38); font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 3px; }
    .upi-val { font-size: 0.95rem; font-weight: 700; color: var(--navy); font-family: monospace; }
    .copy-btn { background: var(--navy); color: white; border: none; padding: 8px 14px; border-radius: 8px; font-size: 0.75rem; font-weight: 600; cursor: pointer; white-space: nowrap; transition: background 0.2s; font-family: 'DM Sans', sans-serif; flex-shrink: 0; }
    .copy-btn:hover { background: #1a3260; }
    .copy-btn.copied { background: var(--green); }

    .summary-box { background: rgba(15,32,68,0.03); border-radius: 12px; padding: 14px 18px; margin-bottom: 22px; }
    .summary-row { display: flex; justify-content: space-between; font-size: 0.85rem; padding: 5px 0; border-bottom: 1px solid rgba(0,0,0,0.05); }
    .summary-row:last-child { border: none; font-weight: 700; color: var(--navy); padding-top: 8px; }
    .summary-row span:first-child { color: rgba(0,0,0,0.45); }

    .btn-done { display: block; width: 100%; background: var(--green); color: white; border: none; padding: 17px; border-radius: 12px; font-family: 'DM Sans', sans-serif; font-size: 1rem; font-weight: 700; cursor: pointer; transition: all 0.25s; box-shadow: 0 4px 16px rgba(22,163,74,0.22); margin-bottom: 10px; letter-spacing: 0.01em; }
    .btn-done:hover { background: #15803d; transform: translateY(-2px); }
    .secure-lbl { text-align: center; font-size: 0.75rem; color: rgba(0,0,0,0.3); }

    /* THANK YOU PAGE */
    .ty-head { background: linear-gradient(135deg, #14532d, #166534); padding: 36px 28px; text-align: center; position: relative; }
    .ty-head::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, transparent, #4ade80, transparent); }
    .tick-circle { width: 70px; height: 70px; background: rgba(255,255,255,0.15); border: 2px solid rgba(255,255,255,0.3); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.9rem; margin: 0 auto 14px; }
    .ty-head h2 { font-family: 'Playfair Display', serif; font-size: 1.55rem; color: white; margin-bottom: 6px; }
    .ty-head p { font-size: 0.82rem; color: rgba(255,255,255,0.6); line-height: 1.6; }

    .ty-body { padding: 24px; }

    .booking-box { background: var(--off-white); border: 1.5px solid rgba(15,32,68,0.07); border-radius: 14px; padding: 18px 20px; margin-bottom: 22px; }
    .booking-box-title { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(0,0,0,0.35); margin-bottom: 12px; }
    .brow { display: flex; justify-content: space-between; align-items: center; padding: 7px 0; border-bottom: 1px solid rgba(0,0,0,0.05); font-size: 0.85rem; }
    .brow:last-child { border: none; }
    .brow .k { color: rgba(0,0,0,0.42); }
    .brow .v { font-weight: 600; color: var(--navy); }
    .brow .v.grn { color: var(--green); }

    /* WA BOX */
    .wa-box { background: rgba(37,211,102,0.05); border: 1.5px solid rgba(37,211,102,0.22); border-radius: 16px; padding: 24px; text-align: center; }
    .wa-emoji { font-size: 2.4rem; margin-bottom: 10px; }
    .wa-box h3 { font-size: 1rem; font-weight: 700; color: var(--navy); margin-bottom: 10px; }
    .wa-instruction { background: white; border-radius: 10px; padding: 14px 16px; margin-bottom: 18px; font-size: 0.85rem; color: rgba(0,0,0,0.55); line-height: 1.7; text-align: left; border: 1px solid rgba(0,0,0,0.06); }
    .wa-instruction strong { color: var(--navy); }
    .wa-number-chip { display: inline-flex; align-items: center; gap: 8px; background: rgba(15,32,68,0.06); border-radius: 8px; padding: 8px 14px; font-size: 0.9rem; font-weight: 700; color: var(--navy); margin-bottom: 18px; font-family: monospace; letter-spacing: 0.05em; }
    .btn-wa { display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; background: var(--wa); color: white; border: none; padding: 16px; border-radius: 12px; font-family: 'DM Sans', sans-serif; font-size: 1rem; font-weight: 700; cursor: pointer; text-decoration: none; transition: all 0.25s; box-shadow: 0 4px 14px rgba(37,211,102,0.28); }
    .btn-wa:hover { background: #1ebe5a; transform: translateY(-2px); }
    .wa-steps { list-style: none; margin-top: 14px; text-align: left; }
    .wa-steps li { font-size: 0.78rem; color: rgba(0,0,0,0.38); padding: 3px 0; display: flex; gap: 8px; }
    .wa-steps li::before { content: '→'; color: var(--wa); font-weight: 700; flex-shrink: 0; }
  </style>
</head>
<body>

<div class="topbar">
  <div class="topbar-name">Adv. <span>Devesh Chandra Gupta</span></div>
  <div class="topbar-sub">Criminal & Family Law · Agra, Uttar Pradesh</div>
</div>

<!-- PAGE 1: PAYMENT -->
<div class="page active" id="page-payment">
  <div class="wrap">
    <div class="step-bar">
      <div class="step active"><div class="step-num">1</div>Pay</div>
      <div class="step-line"></div>
      <div class="step" id="step2"><div class="step-num">2</div>Confirm</div>
    </div>

    <div class="card">
      <div class="pay-head">
        <div class="pill">⚖ Legal Consultation</div>
        <h2>Book Your Consultation Slot</h2>
        <p>30-minute one-on-one session with Adv. Devesh Chandra Gupta</p>
        <div class="fee-pill">
          <span class="cur">₹</span><span class="amt">999</span><span class="lbl">only</span>
        </div>
      </div>

      <div class="pay-body">
        <!-- QR -->
        <div class="qr-section">
          <div class="qr-lbl">📱 Scan QR to Pay</div>
          <div class="qr-frame">
            <img src="data:image/jpeg;base64," alt="UPI QR Code"/>
          </div>
          <div class="qr-apps">GPay &nbsp;·&nbsp; PhonePe &nbsp;·&nbsp; Paytm &nbsp;·&nbsp; BHIM &nbsp;·&nbsp; Any UPI App</div>
        </div>

        <!-- OR -->
        <div class="or-divider">or pay using UPI ID</div>

        <!-- UPI ID -->
        <div class="upi-row">
          <div>
            <div class="upi-lbl">UPI ID</div>
            <div class="upi-val">9258096814@ptaxis</div>
          </div>
          <button class="copy-btn" onclick="copyUPI(this)">Copy</button>
        </div>

        <!-- Summary -->
        <div class="summary-box">
          <div class="summary-row"><span>Legal Consultation (30 min)</span><span>₹999</span></div>
          <div class="summary-row"><span>Platform Fee</span><span>₹0</span></div>
          <div class="summary-row"><span>Total Payable</span><span>₹999</span></div>
        </div>

        <!-- Done -->
        <button class="btn-done" onclick="paymentDone()">✅ &nbsp; I Have Paid — Proceed</button>
        <p class="secure-lbl">🔒 Direct UPI · No third party · 100% secure</p>
      </div>
    </div>
  </div>
</div>

<!-- PAGE 2: THANK YOU -->
<div class="page" id="page-thankyou">
  <div class="wrap">
    <div class="card">
      <div class="ty-head">
        <div class="tick-circle">✅</div>
        <h2>Payment Done!</h2>
        <p>Your booking request has been received.<br/>Complete the last step below to confirm your slot.</p>
      </div>

      <div class="ty-body">
        <!-- Booking summary -->
        <div class="booking-box">
          <div class="booking-box-title">📋 Booking Summary</div>
          <div class="brow"><span class="k">Advocate</span><span class="v">Devesh Chandra Gupta</span></div>
          <div class="brow"><span class="k">Service</span><span class="v">Legal Consultation (30 min)</span></div>
          <div class="brow"><span class="k">Amount Paid</span><span class="v">₹999</span></div>
          <div class="brow"><span class="k">Date</span><span class="v" id="booking-date">—</span></div>
          <div class="brow"><span class="k">Time</span><span class="v" id="booking-time">—</span></div>
          <div class="brow"><span class="k">Status</span><span class="v grn">✅ Payment Received</span></div>
        </div>

        <!-- WhatsApp -->
        <div class="wa-box">
          <div class="wa-emoji">📸</div>
          <h3>One Last Step to Confirm Your Slot</h3>
          <div class="wa-instruction">
            Please send your <strong>payment screenshot</strong> on WhatsApp to confirm your slot. Your consultation time will be shared within <strong>24 hours.</strong>
          </div>
          <div class="wa-number-chip">📱 +91 92580 96814</div>
          <a id="wa-link" href="#" class="btn-wa" target="_blank" rel="noopener">
            💬 &nbsp; Send Screenshot on WhatsApp
          </a>
          <ul class="wa-steps">
            <li>Click the button — WhatsApp will open directly</li>
            <li>Message is pre-written — just hit Send</li>
            <li>Attach your payment screenshot</li>
            <li>You'll receive a confirmation call within 24 hours</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const UPI_ID = "9258096814@ptaxis";
  const WA_NUMBER = "919258096814";

  function copyUPI(btn) {
    navigator.clipboard.writeText(UPI_ID).then(() => {
      btn.textContent = 'Copied ✓';
      btn.classList.add('copied');
      setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 2000);
    });
  }

  function paymentDone() {
    const now = new Date();
    const dateStr = now.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });
    const timeStr = now.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit', hour12: true });
    document.getElementById('booking-date').textContent = dateStr;
    document.getElementById('booking-time').textContent = timeStr;
    const msg = `Hello! I have paid ₹999 for a legal consultation with Adv. Devesh Chandra Gupta.\n\n📅 Date: ${dateStr}\n⏰ Time: ${timeStr}\n\nAttaching payment screenshot. Please confirm my slot. 🙏`;
    document.getElementById('wa-link').href = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(msg)}`;
    document.getElementById('page-payment').classList.remove('active');
    document.getElementById('page-thankyou').classList.add('active');
    document.getElementById('step2').classList.add('active');
    window.scrollTo(0, 0);
  }
</script>
</body>
</html>
